# Montrez Backend API Environment Variables

# Admin Authentication
# Change this to a secure random string for production
ADMIN_TOKEN=montrez-admin-2026

# Email Service (Resend)
# Get free API key from https://resend.com (3,000 emails/month free)
# Required for order confirmation emails
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Optional: Database URL (for future migration from JSON files)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Optional: Redis URL (for cart session management)
# REDIS_URL=redis://localhost:6379
