# MONTREZ EMAIL VERIFICATION - ENVIRONMENT VARIABLES

# Resend API Key (get from https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email sender address (must be verified domain in Resend)
# Default: onboarding@resend.dev (for testing)
# Production: Use your verified domain (e.g., verify@montrez.com)
EMAIL_FROM=MONTREZ <onboarding@resend.dev>

# Optional: Custom branding
# BRAND_NAME=MONTREZ
# BRAND_TAGLINE=Pas pour Tout
