# Montrez Backend API Environment Variables

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://montrez.vercel.app

# Admin Authentication
ADMIN_TOKEN=montrez-admin-2026

# PayFast Payment Gateway (South African payments)
# Sandbox credentials (for testing): merchant_id=10000100, merchant_key=46f0cd694581a
# Get live credentials from https://www.payfast.co.za
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
# Leave passphrase empty for sandbox, set for production
# Set NODE_ENV=production to use live PayFast

# Supabase Database
# Get from https://supabase.com (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend Email Service
# Get free API key from https://resend.com (3,000 emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=MONTREZ <orders@montrez.co.za>

# Frontend Password Protection
VITE_PASSWORD=NOTFOREVERYONE
